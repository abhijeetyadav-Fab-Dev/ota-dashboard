# Copy this to .env and fill in values

# PostgreSQL Database URL (format: postgresql://user:password@host:port/database)
# For local development with Docker: postgresql://postgres:postgres@localhost:5432/ota_dashboard
# For Coolify: Use the DATABASE_URL provided by Coolify's PostgreSQL addon
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/ota_dashboard

# Session secret for JWT signing - MUST be changed in production!
# Generate with: openssl rand -base64 32
# Minimum 32 characters required
SESSION_SECRET=change-me-in-production-use-openssl-rand-base64-32

# Next.js port (default 3000)
PORT=3000

# Set to 'production' in production environments
NODE_ENV=development
